PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database provider for analytics / history ──────────────────
# Local (default) — no config needed, uses SQLite in backend/data/

# PostgreSQL (optional — requires a running PostgreSQL server)
# DATABASE_URL=postgresql://user:password@localhost:5432/fixmydb

# Supabase (optional — production cloud database)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key
# SUPABASE_ANON_KEY=your_anon_key
